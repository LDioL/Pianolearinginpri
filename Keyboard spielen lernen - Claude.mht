.more-item { display: flex; align-items: center; gap: 10px; width: 100%; padding: 8px; border: none; background: transparent; border-radius: 8px; cursor: pointer; text-align: left; color: inherit; transition: background 0.1s; white-space: nowrap; font-family: var(--font-sans, system-ui) !important; }

